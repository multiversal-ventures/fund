rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /data/{allPaths=**} {
      allow read: if request.auth != null &&
                   request.auth.token.email in [
                     'holly@multiversal.ventures',
                     'akshay@multiversal.ventures',
                     'kartik@multiversal.ventures'
                   ];
      allow write: if false;
    }
  }
}
